@{
    ViewData["Title"] = "401 - Unauthorized";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0 rounded-4 text-center p-5">

                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill text-danger" style="font-size:70px;"></i>
                </div>

                <h1 class="display-3 fw-bold text-danger">401</h1>

                <h2 class="mb-3 text-dark">Unauthorized Access</h2>

                <p class="lead text-muted mb-4">
                    Sorry, you do not have permission to view this page.
                    Please sign in with the correct account or return home.
                </p>

                <div class="mb-4">
                    <img src="https://www.publicdomainpictures.net/pictures/280000/velka/not-found-image-15383864787lu.jpg"
                         alt="Unauthorized Access"
                         class="img-fluid rounded-4 shadow-sm"
                         style="max-height:300px; object-fit:cover;">
                </div>

                <div class="d-flex justify-content-center gap-3 flex-wrap">

                    <a asp-controller="Account"
                       asp-action="Login"
                       class="btn btn-danger btn-lg px-4">
                        Sign In
                    </a>

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-outline-primary btn-lg px-4">
                        Back to Home
                    </a>

                </div>

            </div>
        </div>

    </div>
</div>