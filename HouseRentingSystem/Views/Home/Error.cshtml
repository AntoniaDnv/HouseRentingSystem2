@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="container mt-5 text-center">

    <div class="card shadow-lg border-0 rounded-4 p-5">

        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:70px;"></i>
        </div>

        <h1 class="display-4 text-danger fw-bold">Oops!</h1>

        <h2 class="mb-4 text-secondary">
            An unexpected error occurred while processing your request.
        </h2>

        <p class="text-muted fs-5">
            Please try again later or return to the home page.
        </p>

        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                Back to Home
            </a>
        </div>

    </div>

</div>