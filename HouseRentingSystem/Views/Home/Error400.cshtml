@{
    ViewData["Title"] = "400 - Bad Request";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0 rounded-4 text-center p-5">

                <div class="mb-4">
                    <i class="bi bi-exclamation-circle-fill text-warning" style="font-size:70px;"></i>
                </div>

                <h1 class="display-3 fw-bold text-warning">400</h1>

                <h2 class="mb-3 text-dark">Bad Request</h2>

                <p class="lead text-muted mb-4">
                    Oops! The request could not be processed.
                    Please check the URL or try again.
                </p>

                <div class="mb-4">
                    <img src="https://www.publicdomainpictures.net/pictures/280000/velka/not-found-image-15383864787lu.jpg"
                         alt="Bad Request"
                         class="img-fluid rounded-4 shadow-sm"
                         style="max-height:300px; object-fit:cover;">
                </div>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-primary btn-lg px-4">
                        Back to Home
                    </a>

                    <button onclick="history.back()"
                            class="btn btn-outline-secondary btn-lg px-4">
                        Go Back
                    </button>
                </div>

            </div>
        </div>

    </div>
</div>